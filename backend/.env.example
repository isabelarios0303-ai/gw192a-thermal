# Copy to .env and adjust. All vars are prefixed THERMOBABY_.
THERMOBABY_DEBUG=false
THERMOBABY_JWT_SECRET=please-generate-a-long-random-secret
THERMOBABY_CORS_ORIGINS=["https://localhost:3000"]

# Database — PostgreSQL in production, SQLite for local mode
# THERMOBABY_DATABASE_URL=postgresql+psycopg://thermo:thermo@localhost:5432/thermobaby
THERMOBABY_DATABASE_URL=sqlite+pysqlite:///./thermobaby.db

# GW192A calibration (trim against a reference thermometer)
THERMOBABY_SENSOR_WIDTH=192
THERMOBABY_SENSOR_HEIGHT=192
THERMOBABY_KELVIN_SCALE=64.0
THERMOBABY_KELVIN_OFFSET=273.15
THERMOBABY_CALIB_GAIN=1.0
THERMOBABY_CALIB_OFFSET=0.0
THERMOBABY_EMISSIVITY=0.98
