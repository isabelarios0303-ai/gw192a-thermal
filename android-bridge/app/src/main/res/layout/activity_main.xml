<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0b1020"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title"
            android:textColor="#e2e8f0"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <Button
            android:id="@+id/startCameraBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/start_camera" />

        <TextView
            android:id="@+id/readout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Max: --   Min: --   Prom: --"
            android:textColor="#38bdf8"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/alert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_ok"
            android:textColor="#22c55e"
            android:textSize="16sp"
            android:paddingBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Servidor ThermoBaby (modo puente):"
            android:textColor="#94a3b8"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/serverUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/server_hint"
            android:textColor="#e2e8f0"
            android:textColorHint="#64748b"
            android:inputType="textUri" />

        <Button
            android:id="@+id/connectBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/connect"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_idle"
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:paddingTop="20dp" />

    </LinearLayout>
</ScrollView>
